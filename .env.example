# Copy this file to ".env" and fill in your real key.
# The .env file is read at startup by config.py and is NOT committed to version control.

# Required: your Anthropic API key (provided by the client).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: model used for mapping. Defaults to claude-sonnet-4-6.
# Sonnet is accurate on Indian lakh-format numbers and dual-rate tables;
# claude-haiku-4-5 is cheaper/faster but misreads those, so it is not recommended
# for financial accuracy.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: how many invoices to map in parallel. Defaults to 6.
MAX_CONCURRENCY=6

# Optional: USD->INR rate used to show the estimated cost in rupees. Defaults to
# 88. Update to keep the displayed cost current.
USD_TO_INR=88
